      "printExport": "print-or-public-safe-reference-export",
      "safetyStops": ["stale-biological-source", "conservation-stop", "protected-location-input"],
      "readerBoundary": "broad-plausibility-aid-not-current-hatch-report-or-species-certainty"
    },
    {
      "applicationId": "HTH-PP-001",
      "name": "Presentation Planner",
      "stateContract": "all-required-states",
      "saveDelete": "local-save-and-clear",
      "printExport": "print-and-public-safe-share-card",
      "safetyStops": ["equipment-mismatch", "unsupported-current-condition", "protected-location-input"]
    },
    {
      "applicationId": "HTH-RS-001",
