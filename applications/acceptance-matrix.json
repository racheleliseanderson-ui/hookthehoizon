{
  "schemaVersion": 4,
  "effectiveDate": "2026-07-22",
  "publication": "Hook the Horizon",
  "controllingIssue": 96,
  "parallelTemplateIssue": 86,
  "scope": "Unified source and installed-runtime acceptance contract for the five current Hook applications.",
  "requiredStates": [
    "initial",
    "ordinary-success",
    "incomplete",
    "conflicting",
    "stale",
    "unsupported",
    "no-result",
    "source-failure",
    "hard-stop",
    "no-javascript",
    "reset",
    "recovery",
    "save-delete-when-supported",
    "print-export",
    "return-path"
  ],
  "requiredModalities": [
    "desktop",
    "mobile",
    "keyboard-only",
    "screen-reader",
    "zoom-reflow",
    "reduced-motion",
    "forced-colors",
    "print"
  ],
  "freshnessContract": {
    "requiredOfficialFacts": ["regulation", "closure", "access", "hazard", "weather", "waterCondition"],
    "requiredEvidenceFields": ["sourceOwner", "currentCheckUrl", "reviewedAt", "nextReviewAt", "status"],
    "criticalStaleBehavior": "block-result-pending-current-official-verification",
    "noncriticalStaleBehavior": "reduce-confidence-and-name-affected-field",
    "unavailableBehavior": "preserve-unavailable-state-without-favorable-assumption",
    "fixture": "applications/fixtures/official-source-freshness.json"
  },
  "sensitiveLocationContract": {
    "prohibitedClasses": ["exact-coordinates", "map-links-or-codes", "private-access-instructions", "vulnerable-water-identifiers", "contributor-sensitive-information"],
    "requiredLeakSurfaces": ["rendered-pages", "rest-responses", "analytics-payloads", "logs", "exports", "share-states"],
    "requiredBehavior": "reject-private-input-and-recursively-redact-public-output",
    "sharedImplementation": "applications/_shared/privacy.mjs",
    "acceptanceTest": "applications/_shared/tests/freshness-and-location.mjs"
  },
  "readerJourneyContract": {
    "primarySystemSource": "next-generation/PRIMARY_EDITORIAL_SYSTEMS.md",
    "routeRegistry": "next-generation/migration/primary-sections.json",
    "continuationRegistry": "applications/result-continuations.json",
    "validator": "scripts/validate-reader-journeys.mjs",
    "requiredEntrySurfaces": ["homepage", "start-here", "primary-navigation", "field-systems-studio"],
    "requiredContinuationKinds": ["field-guide-or-resource", "current-check-or-next-decision", "start-here-return"],
    "prohibitedPresentation": ["generic-dashboard", "dead-destination", "placeholder-destination"]
  },
  "installedHarness": {
    "runner": "Playwright Chromium",
    "accessibilityEngine": "Axe Core",
    "configuration": "tests/installed-acceptance/playwright.config.mjs",
    "specification": "tests/installed-acceptance/specs/five-applications.spec.mjs",
    "workflow": ".github/workflows/five-application-acceptance.yml",
    "runtime": "isolated-wp-env",
    "projects": ["chromium", "mobile-chromium", "chromium-nojs", "print-chromium"],
    "artifactRetentionDays": 30,
    "failureRetention": "always-upload-even-when-tests-fail"
  },
  "applications": [
    {
      "applicationId": "HTH-SC-001",
      "name": "Compatibility Builder",
      "stateContract": "all-required-states",
      "saveDelete": "local-save-and-clear",
