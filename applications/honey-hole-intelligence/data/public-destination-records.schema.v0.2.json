{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hookthehorizon.blog/schemas/public-destination-records.v0.2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "applicationId", "generatedAt", "coverage", "destinations"],
  "properties": {
    "schemaVersion": {"const": "0.2.0"},
    "applicationId": {"const": "HHI-001"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "coverage": {
      "type": "object",
      "required": ["states", "destinationCount", "boundary"],
      "properties": {
        "states": {"type": "array", "minItems": 2, "items": {"type": "string"}, "uniqueItems": true},
        "destinationCount": {"type": "integer", "minimum": 1},
        "boundary": {"type": "string", "minLength": 40}
      }
    },
    "destinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "state", "region", "waterbody", "waterType", "officialSourceUrl", "checkedAt", "nextReviewAt", "status", "publicAccess", "currentNotices", "directVerification", "privacy"],
        "properties": {
          "id": {"type": "string", "pattern": "^HHI-DEST-[0-9]{3}$"},
          "state": {"type": "string", "minLength": 2},
          "region": {"type": "string", "minLength": 2},
          "waterbody": {"type": "string", "minLength": 2},
          "waterType": {"enum": ["lake", "reservoir", "river", "stream", "marine", "pond"]},
          "officialSourceUrl": {"type": "string", "format": "uri", "pattern": "^https://"},
          "checkedAt": {"type": "string", "format": "date-time"},
          "nextReviewAt": {"type": "string", "format": "date"},
          "status": {"type": "string", "minLength": 2},
          "publicCoordinates": {
            "type": "object",
            "required": ["latitude", "longitude", "sourceType"],
            "properties": {
              "latitude": {"type": "number", "minimum": -90, "maximum": 90},
              "longitude": {"type": "number", "minimum": -180, "maximum": 180},
              "sourceType": {"type": "string", "minLength": 2}
            }
          },
          "publicAccess": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "type", "officiallyPublished"],
              "properties": {
                "name": {"type": "string", "minLength": 2},
                "type": {"type": "string", "minLength": 2},
                "officiallyPublished": {"const": true}
              }
            }
          },
          "currentNotices": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
          "directVerification": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
          "privacy": {
            "type": "object",
            "required": ["classification", "publicLocationIncluded", "sensitiveLocationIncluded"],
            "properties": {
              "classification": {"const": "public_destination"},
              "publicLocationIncluded": {"const": true},
              "sensitiveLocationIncluded": {"const": false}
            }
          }
        }
      }
    }
  }
}