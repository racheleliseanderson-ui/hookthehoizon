{
  "$schema":"https://schemas.wp.org/trunk/theme.json",
  "version":3,
  "customTemplates":[
    {"name":"page-legal","title":"Legal and Trust Page","postTypes":["page"]},
    {"name":"page-reader-pathway","title":"Conditions and Stewardship Pathway","postTypes":["page"]},
    {"name":"page-application","title":"Hook Intelligence Application","postTypes":["page"]},
    {"name":"page-storefront","title":"Hook Storefront","postTypes":["page"]}
  ],
  "templateParts":[
    {"name":"header","title":"Hook the Horizon Header","area":"header"},
    {"name":"footer","title":"Hook the Horizon Footer","area":"footer"}
  ],
  "settings":{
    "appearanceTools":true,
    "useRootPaddingAwareAlignments":true,
    "color":{
      "custom":false,"customDuotone":false,"customGradient":false,"defaultPalette":false,"defaultGradients":false,
      "palette":[
        {"slug":"deep-navy","name":"Deep Navy","color":"#071827"},
        {"slug":"pearl","name":"Pearl","color":"#E3E1D9"},
        {"slug":"lake-blue","name":"Lake Blue","color":"#2E6F95"},
        {"slug":"teal","name":"Teal","color":"#176F78"},
        {"slug":"charcoal","name":"Charcoal","color":"#424546"},
        {"slug":"forest-green","name":"Forest Green","color":"#355133"},
        {"slug":"burnt-coral","name":"Burnt Coral","color":"#D55C3E"},
        {"slug":"champagne-gold","name":"Champagne Gold","color":"#C7A257"}
      ],
      "gradients":[
        {"slug":"open-water","name":"Open Water","gradient":"linear-gradient(180deg,#E3E1D9 0%,#2E6F95 38%,#176F78 68%,#071827 100%)"},
        {"slug":"horizon-light","name":"Horizon Light","gradient":"linear-gradient(135deg,#071827 0%,#2E6F95 62%,#C7A257 100%)"}
      ]
    },
    "layout":{"contentSize":"46rem","wideSize":"96rem"},
    "spacing":{"units":["px","rem","em","vw","vh","%"],"spacingSizes":[
      {"slug":"20","name":"2XS","size":"0.5rem"},{"slug":"30","name":"XS","size":"0.75rem"},{"slug":"40","name":"S","size":"1.25rem"},{"slug":"50","name":"M","size":"2rem"},{"slug":"60","name":"L","size":"clamp(3.5rem,8vw,8rem)"},{"slug":"70","name":"XL","size":"clamp(5rem,10vw,10rem)"}
    ]},
    "typography":{"fluid":true,"lineHeight":true,"letterSpacing":true,"fontFamilies":[
      {"slug":"display","name":"Bebas Neue Display","fontFamily":"'Bebas Neue', Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif"},
      {"slug":"body","name":"Montserrat Body and Interface","fontFamily":"Montserrat, 'Avenir Next', Avenir, 'Segoe UI', system-ui, sans-serif"},
      {"slug":"data","name":"Montserrat Data","fontFamily":"Montserrat, 'Avenir Next', Avenir, 'Segoe UI', system-ui, sans-serif"}
    ],"fontSizes":[
      {"slug":"small","name":"Small","size":"0.875rem"},{"slug":"body","name":"Body","size":"clamp(1rem, .35vw + .94rem, 1.125rem)"},{"slug":"lead","name":"Lead","size":"clamp(1.15rem, 1.6vw, 1.45rem)"},{"slug":"h3","name":"Heading 3","size":"clamp(1.5rem, 2.5vw, 2.25rem)"},{"slug":"h2","name":"Heading 2","size":"clamp(2.25rem, 4.5vw, 4.25rem)"},{"slug":"h1","name":"Heading 1","size":"clamp(3rem, 7vw, 6.5rem)"},{"slug":"display","name":"Display","size":"clamp(3.75rem, 10vw, 9rem)"}
    ]},
    "custom":{"hth":{"visualAuthority":"v3.0-2026-07-23","colorAloneProhibited":true,"locationPrivacyRequired":true,"fontFilesBundled":false,"logoSource":"owner-approved Drive and WordPress media library","homepagePeople":false,"visualGrammar":"cinematic horizon, field evidence, deliberate dark/light transitions"}}
  },
  "styles":{
    "color":{"background":"var(--re-background-canvas)","text":"var(--re-text-primary)"},
    "spacing":{"blockGap":"1.5rem","padding":{"left":"clamp(1rem,3vw,2.75rem)","right":"clamp(1rem,3vw,2.75rem)"}},
    "typography":{"fontFamily":"var:preset|font-family|body","fontSize":"var:preset|font-size|body","lineHeight":"1.65"},
    "elements":{
      "heading":{"color":{"text":"var(--re-heading)"},"typography":{"fontFamily":"var:preset|font-family|display","fontWeight":"400","lineHeight":"0.98","letterSpacing":"0.01em"}},
      "link":{"color":{"text":"var(--re-link)"},"typography":{"textDecoration":"underline"},":hover":{"color":{"text":"var(--re-link-hover)"}}},
      "button":{"border":{"radius":"0.125rem"},"color":{"background":"var(--re-action-primary)","text":"var(--re-action-primary-text)"},"typography":{"fontFamily":"var:preset|font-family|body","fontSize":"0.9rem","fontWeight":"700","letterSpacing":"0.04em"}}
    },
    "blocks":{"core/table":{"typography":{"fontFamily":"var:preset|font-family|data"}},"core/code":{"typography":{"fontFamily":"var:preset|font-family|data"}}}
  }
}
