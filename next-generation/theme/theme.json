{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "customTemplates": [
    {"name": "page-legal", "title": "Legal and Trust Page", "postTypes": ["page"]},
    {"name": "page-reader-pathway", "title": "Conditions and Stewardship Pathway", "postTypes": ["page"]},
    {"name": "page-application", "title": "Honey Hole Intelligence Application", "postTypes": ["page"]},
    {"name": "page-storefront", "title": "Storefront", "postTypes": ["page"]}
  ],
  "templateParts": [
    {"name": "header", "title": "Hook the Horizon Header", "area": "header"},
    {"name": "footer", "title": "Hook the Horizon Footer", "area": "footer"}
  ],
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        {"slug": "depth-navy", "name": "Depth Navy", "color": "#071827"},
        {"slug": "horizon-blue", "name": "Horizon Blue", "color": "#2E6F95"},
        {"slug": "current-teal", "name": "Current Teal", "color": "#176F78"},
        {"slug": "foam-white", "name": "Foam White", "color": "#F6F3EA"},
        {"slug": "mineral-fog", "name": "Mineral Fog", "color": "#D9D7CE"},
        {"slug": "field-kelp", "name": "Field Kelp", "color": "#4C604A"},
        {"slug": "signal-vermilion", "name": "Signal Vermilion", "color": "#E45E3B"},
        {"slug": "sunlit-brass", "name": "Sunlit Brass", "color": "#C7A257"},
        {"slug": "cold-sky", "name": "Cold Sky", "color": "#AEBCC0"},
        {"slug": "ink", "name": "Ink", "color": "#14232C"}
      ],
      "gradients": [
        {"slug": "open-water", "name": "Open Water", "gradient": "linear-gradient(180deg,#8EC6DE 0%,#2E6F95 46%,#176F78 72%,#071827 100%)"},
        {"slug": "field-signal", "name": "Field Signal", "gradient": "linear-gradient(135deg,#4C604A 0%,#176F78 55%,#E45E3B 100%)"}
      ]
    },
    "layout": {"contentSize": "45rem", "wideSize": "90rem"},
    "spacing": {
      "blockGap": true,
      "customSpacingSize": true,
      "spacingSizes": [
        {"slug": "20", "name": "2XS", "size": "0.5rem"},
        {"slug": "30", "name": "XS", "size": "0.875rem"},
        {"slug": "40", "name": "S", "size": "1.5rem"},
        {"slug": "50", "name": "M", "size": "2.5rem"},
        {"slug": "60", "name": "L", "size": "4rem"},
        {"slug": "70", "name": "XL", "size": "6.5rem"}
      ],
      "units": ["px", "rem", "em", "vw", "vh", "%"]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {"slug": "editorial", "name": "Editorial Serif", "fontFamily": "Georgia, 'Times New Roman', serif"},
        {"slug": "field", "name": "Field Sans", "fontFamily": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"},
        {"slug": "data", "name": "Field Data Mono", "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"}
      ],
      "fontSizes": [
        {"slug": "small", "name": "Small", "size": "0.875rem"},
        {"slug": "medium", "name": "Medium", "size": "1.05rem"},
        {"slug": "large", "name": "Large", "size": "clamp(1.2rem,2vw,1.45rem)"},
        {"slug": "x-large", "name": "Display", "size": "clamp(3.2rem,8vw,8.2rem)"}
      ],
      "lineHeight": true,
      "letterSpacing": true
    },
    "useRootPaddingAwareAlignments": true,
    "custom": {
      "motion": {"micro": "150ms", "standard": "280ms", "editorial": "560ms", "ease": "cubic-bezier(0.22,1,0.36,1)"},
      "image": {"grading": "bright field light, brilliant water and sky, visible conditions and material wear", "homepagePeople": false},
      "field": {"colorAloneProhibited": true, "regulationStateRequiresLabel": true, "locationPrivacyRequired": true}
    }
  },
  "styles": {
    "color": {"background": "var:preset|color|foam-white", "text": "var:preset|color|ink"},
    "spacing": {"blockGap": "1.5rem", "padding": {"left": "clamp(1rem,3vw,2.5rem)", "right": "clamp(1rem,3vw,2.5rem)"}},
    "typography": {"fontFamily": "var:preset|font-family|field", "fontSize": "var:preset|font-size|medium", "lineHeight": "1.62"},
    "elements": {
      "heading": {"color": {"text": "var:preset|color|depth-navy"}, "typography": {"fontFamily": "var:preset|font-family|editorial", "fontWeight": "400", "lineHeight": "1.01"}},
      "link": {"color": {"text": "var:preset|color|current-teal"}, "typography": {"textDecoration": "underline"}, ":hover": {"color": {"text": "var:preset|color|signal-vermilion"}}},
      "button": {"border": {"radius": "0.125rem"}, "color": {"background": "var:preset|color|signal-vermilion", "text": "var:preset|color|depth-navy"}, "typography": {"fontFamily": "var:preset|font-family|field", "fontSize": "0.82rem", "fontWeight": "750", "letterSpacing": "0.08em", "textTransform": "uppercase"}}
    }
  }
}
